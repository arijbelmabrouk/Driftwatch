# Your JWT secret for Driftwatch API authentication
# Generate a strong random value and keep it secret.
JWT_SECRET=replace-with-a-strong-secret

# Optional: token expiration in seconds (default 86400 = 24 hours)
JWT_EXPIRATION_SECONDS=86400

# SMTP configuration for sending report emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
GMAIL_SENDER_EMAIL=your-sender@gmail.com
GMAIL_SENDER_PASSWORD=your-app-password
git log -p --all | grep "YOUR_TOKEN_STRING"